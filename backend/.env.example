# ============================================================
# 智能旅行助手 · 后端环境配置模板
# ------------------------------------------------------------
# 用法: 复制本文件为 .env 后填入真实 key (.env 已被 .gitignore 排除,
#       不会被 push 到 GitHub)
#
#   $ cp .env.example .env   # macOS/Linux
#   $ copy .env.example .env # Windows
#
# ⚠️  绝对不要把 .env 文件 commit 进 git!
# ============================================================


# ────────────────────────────────────────────────────
# 1. LLM 配置 (必填) — 推荐千问 qwen-plus
# ────────────────────────────────────────────────────
# 申请: https://bailian.console.aliyun.com (阿里云百炼)
LLM_API_KEY=sk-your-llm-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_ID=qwen-plus
# 单次 LLM 调用超时 (秒); 国内网络建议 ≥120
LLM_TIMEOUT=240


# ────────────────────────────────────────────────────
# 2. 高德地图 (必填) — Web 服务 API
# ────────────────────────────────────────────────────
# 申请: https://console.amap.com/dev/key/app
# ⚠️  必须选 "Web 服务" 类型, "Web 端 (JS API)" 不能用!
AMAP_API_KEY=your-amap-web-service-key-here


# ────────────────────────────────────────────────────
# 3. Unsplash (可选,仅作图片 fallback 兜底)
# ────────────────────────────────────────────────────
# 申请: https://unsplash.com/developers (注册即可)
# 留空也能跑 (会跳过 Unsplash 直接显示 SVG 占位图)
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=


# ────────────────────────────────────────────────────
# 4. 服务器 / CORS / 日志 (默认值通常够用)
# ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO
